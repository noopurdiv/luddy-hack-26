# Copy to `.env` and adjust for your environment.
# Docker Compose loads this file automatically as `env_file` for services and for `${VAR}` substitution.

# --- Shared infrastructure -------------------------------------------------
# Redis URL used by API services (DB 0).
REDIS_URL=redis://redis:6379/0

# Service base URLs inside the Docker network (server-side / worker calls).
OCR_SERVICE_URL=http://service_ocr:8001
COMPRESS_SERVICE_URL=http://service_compress:8002

# --- Frontend (Vite build args) -------------------------------------------
# URLs must be reachable from the USER'S BROWSER on the host when using published ports.
VITE_OCR_URL=http://localhost:8001
VITE_COMPRESS_URL=http://localhost:8002
